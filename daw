# --- 4. ANA SAYFA BAŞLIĞI VE SOHBET ALANI ---
# Burası sitenin orta kısmıdır.
st.markdown("<h1>🤖 NovaAi - Senin Dijital Dostun</h1>", unsafe_allow_html=True)
st.markdown("<p class='subtitle'>Bana ne sormak istersen sor, çekinme!</p>", unsafe_allow_html=True)

# Sohbet Geçmişini Hafızada Tutma
if "messages" not in st.session_state:
    st.session_state.messages = []

# Eski Mesajları Ekrana Yazdırma
for message in st.session_state.messages:
    with st.chat_message(message["role"]):
        st.markdown(message["content"])

# Kullanıcıdan Mesaj Alma (Sohbet Kutusu)
if prompt := st.chat_input("Buraya yaz ve bana gönder..."):
    # Kullanıcının yazdığını ekrana bas
    with st.chat_message("user"):
        st.markdown(prompt)
    st.session_state.messages.append({"role": "user", "content": prompt})

    # Yapay zekadan cevap üretme
    with st.chat_message("assistant"):
        message_placeholder = st.empty()
        
        # --- 5. BOTA BENİM GİBİ KONUŞMASINI SÖYLÜYORUZ (Sistem Talimatı) ---
        system_instruction = (
            "Sen samimi, cana yakın ama yeri geldiğinde tatlı sert çıkışabilen, "
            "asla pes etmeyen zeki bir yapay zeka asistanısın. Tıpkı Gemini gibisin. "
            "Kullanıcıya ismiyle hitap edebilir, onunla empati kurabilirsin ama "
            "hatalarını da kibarca yüzüne vurabilirsin. Resmi konuşma, arkadaşınla konuşur gibi doğal ol. "
            "Cevaplarında Türkçe kullan ve bazen hafif espriler yap."
        )
        
        # Google API URL'si
        url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={api_key}"
        
        headers = {'Content-Type': 'application/json'}
        
        # Sohbet geçmişini ve yeni mesajı API'ye gönderilecek formata sokuyoruz
        formatted_contents = []
        for msg in st.session_state.messages:
            role_map = "user" if msg["role"] == "user" else "model"
            formatted_contents.append({
                "role": role_map,
                "parts": [{"text": msg["content"]}]
            })
            
        # Sistem talimatını en başa ekliyoruz
        formatted_contents.insert(0, {
            "role": "user",
            "parts": [{"text": f"Sistem Talimatı: {system_instruction}"}]
        })

        payload = {
            "contents": formatted_contents
        }
        
        try:
            # API'ye isteği gönderiyoruz
            response = requests.post(url, headers=headers, json=payload)
            response_data = response.json()
            
            # API'den gelen cevabı ayıklıyoruz
            full_response = response_data['candidates'][0]['content']['parts'][0]['text']
        except Exception as e:
            full_response = "Üzgünüm, bir hata oluştu. Lütfen Streamlit Secrets kısmındaki API anahtarınızı kontrol edin."
            
        # Botun cevabını ekrana yazdırıyoruz
        message_placeholder.markdown(full_response)
        
    st.session_state.messages.append({"role": "assistant", "content": full_response})
